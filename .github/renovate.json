{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>cgrindel/renovate_presets:ruleset_base",
    "github>cgrindel/renovate_presets:cgrindel_default"
  ],
  "postUpgradeTasks": {
    "commands": [
      "./do_renovate_post_upgrade"
    ],
    "executionMode": "branch"
  },
  "packageRules": [
    {
      "matchPackagePatterns": ["buildtools"],
      "matchManagers": ["gomod"],
      "enabled": false
    },
    {
      "description": "The fake registry used by swift_package_registry_example only hosts swift-collections 1.1.x, which is incompatible with swift-async-algorithms >= 1.1.4 (requires swift-collections >= 1.5.0).",
      "matchPackageNames": ["apple/swift-async-algorithms"],
      "matchFileNames": ["examples/swift_package_registry_example/Package.swift"],
      "enabled": false
    }
  ]
}
