# Ignore Bazel symlinks
bazel-*

# Ignore Bazel lock files
**/MODULE.bazel.lock

# Ignore Swift and Xcode stuff
.DS_Store
**/.build
**/Packages
**/*.xcodeproj
**/xcuserdata/
**/DerivedData/
**/.swiftpm/config/registries.json
**/.swiftpm/xcode/package.xcworkspace/contents.xcworkspacedata
**/.netrc

# Ignore the local.bazelrc
local.bazelrc

# Ignore vscode settings
.vscode

# Ignore Claude Code local files
.claude/settings.local.json
.claude/scheduled_tasks.lock

# This is generated by the firebase example's tools/bazel.
examples/firebase_example/tools/bazel_for_xcodeproj
